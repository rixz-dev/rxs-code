# ═══════════════════════════════════════════════════
# RXS CODE — Multi-Provider Config
# ═══════════════════════════════════════════════════
# Provider: "groq" | "nvidia" | "openrouter" | "gemini" | "auto"
# "auto" = detect dari key yang ada (priority: groq → openrouter → gemini → nvidia)
RXS_PROVIDER=auto

# === WEB TOOLS ===

# Tavily — https://app.tavily.com (1000 searches/month free, no CC)
# Enables: web_search + web_fetch tools for the AI
# Key format: tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY

# ── GROQ ──────────────────────────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=

# ── OPENROUTER ────────────────────────────────────
# https://openrouter.ai/keys  (sk-or-...)
# 500+ models, 1 key — recommended untuk eksplor model
OPENROUTER_API_KEY=
# ── GEMINI ────────────────────────────────────────
# https://aistudio.google.com/apikey
# Free tier: 15 req/min, 1M context
GEMINI_API_KEY=
# ── NVIDIA NIM ────────────────────────────────────
# https://build.nvidia.com
NVIDIA_NIM_API_KEY=
# Kimi (Moonshot AI) — https://platform.moonshot.ai
KIMI_API_KEY=

# Qwen (Alibaba DashScope) — https://alibabacloud.com → Model Studio
# Region: sg (Singapore, default) | us | cn
QWEN_API_KEY=
QWEN_REGION=sg

# MiniMax — https://platform.minimax.io
MINIMAX_API_KEY=

# === BATCH 2 PROVIDERS ===

# Cerebras — https://cloud.cerebras.ai (1M tokens/day, no CC, fastest inference)
CEREBRAS_API_KEY=

# Mistral AI — https://console.mistral.ai (1B tokens/month free, all models)
MISTRAL_API_KEY=

# xAI (Grok) — https://console.x.ai ($25 signup + $150/mo data sharing)
XAI_API_KEY=

# SambaNova — https://cloud.sambanova.ai (free via email, fast RDU hardware)
SAMBANOVA_API_KEY=

# Together AI — https://api.together.ai (~$100 signup credits, largest OSS catalog)
TOGETHER_API_KEY=

# ── Model & Settings ──────────────────────────────
# Default: auto (pakai defaultModel dari provider)
# Override contoh: gemini-2.5-flash, google/gemini-2.5-flash, moonshotai/kimi-k2
RXS_DEFAULT_MODEL=auto

RXS_MAX_CONTEXT_TOKENS=120000
RXS_MAX_RESPONSE_TOKENS=8000
RXS_TEMPERATURE=0.7
RXS_PERMISSION_MODE=default
